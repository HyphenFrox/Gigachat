+// Gigachat patch (rpc-resilience): EAGAIN / EWOULDBLOCK / EINTR are transient
+// kernel-side errors that the original llama.cpp code surfaces as a hard
+// failure, killing the entire llama-server with STATUS_STACK_BUFFER_OVERRUN
+// when the upstream RPC_STATUS_ASSERT fires. On a real production LAN with
+// Wi-Fi blips and TCP back-pressure these happen routinely. Retrying with
+// a short backoff for a bounded number of attempts converts almost every
+// observed crash into a brief stall that the chat layer doesn't notice.
+//
+// The retry budget is intentionally small (8 attempts, ~250 ms total at
+// most) so a TRULY dead peer still surfaces as a clean false return — the
+// higher layer can then demote the RPC backend rather than spin forever.
+static bool _gigachat_errno_is_transient() {
+#ifdef _WIN32
+    int e = WSAGetLastError();
+    return e == WSAEINTR || e == WSAEWOULDBLOCK || e == WSAETIMEDOUT;
+#else
+    return errno == EINTR || errno == EAGAIN || errno == EWOULDBLOCK;
+#endif
+}
+
+static void _gigachat_short_sleep(int attempt) {
+#ifdef _WIN32
+    Sleep((attempt + 1) * 5);  // 5, 10, 15, ... ms
+#else
+    struct timespec ts = { 0, (attempt + 1) * 5 * 1000 * 1000 };
+    nanosleep(&ts, nullptr);
+#endif
+}
