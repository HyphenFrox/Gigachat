@@ -26,8 +27,39 @@ static const char * RPC_DEBUG = std::getenv("GGML_RPC_DEBUG");
 
 namespace fs = std::filesystem;
 
-// macro for nicer error messages on server crash
-#define RPC_STATUS_ASSERT(x) if (!(x)) GGML_ABORT("Remote RPC server crashed or returned malformed response")
+// Gigachat patch (rpc-resilience): the upstream macro calls GGML_ABORT
+// which on Windows is __fastfail(STATUS_STACK_BUFFER_OVERRUN) — a hard
+// process kill with no way for the chat layer to recover. Real production
+// LANs lose the connection occasionally (Wi-Fi roaming, peer wakes from
+// sleep, 5 GHz channel hop), and every blip became a crashed llama-server.
+//
+// New behaviour: throw a std::runtime_error instead of aborting. C++
+// exceptions unwind cleanly through every RPC_STATUS_ASSERT site (these
+// macros have many different return types — bool, size_t, void*, void —
+// and `throw` is the only mechanism that works in all of them). The
+// llama-server main loop catches std::runtime_error around the inference
+// call and surfaces a clean HTTP 503 to the client; Gigachat's chat
+// layer (agent.py:_stream_llama_server_chat) sees the 503 and retries
+// the request via its existing auto-retry path. Net effect: a transient
+// RPC failure becomes a brief stall instead of a process death.
+//
+// Kept behind GIGACHAT_RPC_STRICT_ABORT so developers can crash on
+// every assertion (useful while debugging the protocol itself).
+class rpc_remote_failure : public std::runtime_error {
+  public:
+    rpc_remote_failure() : std::runtime_error(
+        "Remote RPC server crashed or returned malformed response") {}
+};
+#ifdef GIGACHAT_RPC_STRICT_ABORT
+#  define RPC_STATUS_ASSERT(x) if (!(x)) GGML_ABORT("Remote RPC server crashed or returned malformed response")
+#else
+#  define RPC_STATUS_ASSERT(x) do { \
+        if (!(x)) { \
+            GGML_LOG_ERROR("Remote RPC server failure caught (Gigachat soft-fail; throwing recoverable rpc_remote_failure)\n"); \
+            throw rpc_remote_failure(); \
+        } \
+    } while (0)
+#endif
 
 // all RPC structures must be packed
 #pragma pack(push, 1)
@@ -399,8 +431,16 @@ static std::shared_ptr<socket_t> get_socket(const std::string & endpoint) {
 static void ggml_backend_rpc_buffer_free_buffer(ggml_backend_buffer_t buffer) {
     ggml_backend_rpc_buffer_context * ctx = (ggml_backend_rpc_buffer_context *)buffer->context;
     rpc_msg_free_buffer_req request = {ctx->remote_ptr};
+    // Gigachat patch: don't throw from a free-buffer / destructor-like
+    // path. The patched macro propagates failures via std::runtime_error,
+    // but throwing here unwinds through C-only call frames in ggml's
+    // backend dispatcher and terminates the process. Log + leak the
+    // remote buffer instead — the rpc-server process will free it on
+    // its own destructor when the next chat session reconnects.
     bool status = send_rpc_cmd(ctx->sock, RPC_CMD_FREE_BUFFER, &request, sizeof(request), nullptr, 0);
-    RPC_STATUS_ASSERT(status);
+    if (!status) {
+        GGML_LOG_ERROR("Remote RPC server failed to free buffer (Gigachat soft-fail; remote ptr leaked, will be reclaimed on rpc-server restart)\n");
+    }
     delete ctx;
 }
 
