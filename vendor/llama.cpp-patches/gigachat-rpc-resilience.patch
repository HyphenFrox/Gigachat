-        ssize_t n = send(fd, (const char *)data + bytes_sent, size_to_send, 0);
+        ssize_t n = -1;
+        for (int attempt = 0; attempt < 8; ++attempt) {
+            n = send(fd, (const char *)data + bytes_sent, size_to_send, 0);
+            if (n >= 0) break;
+            if (!_gigachat_errno_is_transient()) break;
+            _gigachat_short_sleep(attempt);
+        }
         if (n < 0) {
             GGML_LOG_ERROR("send failed (bytes_sent=%zu, size_to_send=%zu)\n",
                            bytes_sent, size_to_send);
@@ -488,7 +523,15 @@ bool socket_t::impl::recv_data(void * data, size_t size) {
     size_t bytes_recv = 0;
     while (bytes_recv < size) {
         size_t size_to_recv = std::min(size - bytes_recv, MAX_CHUNK_SIZE);
-        ssize_t n = recv(fd, (char *)data + bytes_recv, size_to_recv, 0);
+        ssize_t n = -1;
+        for (int attempt = 0; attempt < 8; ++attempt) {
+            n = recv(fd, (char *)data + bytes_recv, size_to_recv, 0);
