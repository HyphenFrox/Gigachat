# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/
.pytest_cache/

# Node / Vite
node_modules/
dist/
.vite/

# App data (SQLite DB, user conversations)
data/

# SQLite artifacts anywhere in the tree (stray dev DBs, WAL/SHM sidecars).
*.db
*.db-shm
*.db-wal

# Secrets — belt and braces on top of data/ being ignored.
.env
.env.*
*.pem
*.key
auth.json
auth_secret.key
vapid.json
# GCP service-account credentials — local-only, never commit. Both
# the folder layout we use (`GCP Service account/`) and any stray
# `*-service-account*.json` keys land in here as a safety net.
GCP Service account/
GCP_Service_account/
*-service-account*.json
*adept-odyssey*.json

# Per-machine connection details (Tailscale IPs, SSH config notes).
# Contains identifying network info — never commit.
DEVICES.md

# Claude Code local state
.claude/
.claude-test/

# Transient output from scripts/drive_real_conversation.py
scripts/.last_conv_id
scripts/.last_run.log

# Runtime backend log written by the dev launch script
# (`python -m uvicorn ... > gigachat.log 2>&1`). Never useful to
# commit — contains transient request URLs, peer IPs, and per-run
# system stats.
gigachat.log
gigachat.err

# Local debug-log captures gathered for upstream issue reports
# (e.g. github.com/ggml-org/llama.cpp/issues/22643). Each repro
# bundle goes under .gh-NNNNN-logs/ — kept on disk so we can
# re-attach to comments, but never committed.
.gh-*-logs/

# UIAutomation COM-init complaint file written from a background thread
# during some tool tests. Transient; never useful to commit.
@AutomationLog.txt

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
