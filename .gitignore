# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/
.pytest_cache/

# Node / Vite
node_modules/
dist/
.vite/

# App data (SQLite DB, user conversations)
data/

# SQLite artifacts anywhere in the tree (stray dev DBs, WAL/SHM sidecars).
*.db
*.db-shm
*.db-wal

# Secrets — belt and braces on top of data/ being ignored.
.env
.env.*
*.pem
*.key
auth.json
auth_secret.key
vapid.json

# Per-machine connection details (Tailscale IPs, SSH config notes).
# Contains identifying network info — never commit.
LAPTOP.md

# Claude Code local state
.claude/
.claude-test/

# Transient output from scripts/drive_real_conversation.py
scripts/.last_conv_id
scripts/.last_run.log

# UIAutomation COM-init complaint file written from a background thread
# during some tool tests. Transient; never useful to commit.
@AutomationLog.txt

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
